# Foundry build artifacts (regenerated by `forge build`)
out/
cache/

# Secrets — never commit (use contracts/.env locally)
.env
.env.*
!.env.example

# Dependencies (forge-std, openzeppelin) are git submodules — keep lib/ tracked.
# Uncomment only if your team reinstalls via `forge install` on every clone:
# lib/

# Local deployment logs (Anvil, dry-run)
broadcast/
!/broadcast
/broadcast/*/31337/
/broadcast/**/dry-run/

# Foundry template extras
.logs/
.ignore/

# ------------------------------------------------------------------------------
# Repository root — global ignores (applies to all subfolders)
# ------------------------------------------------------------------------------

# Environment & secrets (any path in the repo)
.env
.env.*
!.env.example

# Editor / OS
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/
!.vscode/extensions.json

# Project-specific (local docs, Cursor)
.cursor/
docs/internal/

# Dependencies & build outputs (when present at root or in apps)
node_modules/
dist/
.turbo/

# Foundry (also listed in contracts/.gitignore — redundancy is OK)
contracts/out/
contracts/cache/
contracts/broadcast/

# Next.js (also listed in frontend/.gitignore when created)
frontend/.next/
frontend/out/

# Copy to frontend/.env.local — never commit real values
# NEXT_PUBLIC_* are exposed to the browser; do not put PRIVATE_KEY here

# WalletConnect / RainbowKit (https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=TODO_WALLETCONNECT_PROJECT_ID

# Sepolia RPC for Wagmi / Viem
NEXT_PUBLIC_ALCHEMY_SEPOLIA_RPC=https://eth-sepolia.g.alchemy.com/v2/TODO_ALCHEMY_KEY

# CrowdfundingFactory address after deploy (from contracts/script)
NEXT_PUBLIC_CROWDFUNDING_FACTORY_ADDRESS=0xTODO_FACTORY_ADDRESS

# Optional: local Anvil during development
# NEXT_PUBLIC_CHAIN_ID=31337

# Off-chain metadata (Etapa 3+) — MongoDB Atlas or local
MONGODB_URI=mongodb://127.0.0.1:27017/crowdfunding
